# =========================================================================
#   THE BIG BOSS IDEA - UNIFIED ENVIRONMENT CONFIGURATION TEMPLATE
#   Copy this file to .env in the root and fill in your secrets.
# =========================================================================

# Connection string for Neon PostgreSQL database (with SSL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Port for the Express backend server (default: 5000)
BACKEND_PORT=5000

# Next.js frontend envs (Publicly available to client)
NEXT_PUBLIC_BACKEND_URL="http://localhost:5000"

# Stuck-on Alert Threshold in Milliseconds (e.g., 7200000 = 2 hours, 120000 = 2 minutes for demo)
STUCK_ON_THRESHOLD_MS=7200000

# Gemini AI API Configuration
# Default provider is 'gemini'. Can be swapped or configured.
AI_API_PROVIDER="gemini"
AI_API_KEY="your-gemini-api-key-here"

# Discord Bot Token and Webhook URL
DISCORD_BOT_TOKEN="your-discord-bot-token-here"
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/your-webhook-url-here"
