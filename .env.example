# =========================================================================
#   THE BIG BOSS IDEA - UNIFIED ENVIRONMENT CONFIGURATION
#   Copy this file to .env in the root and fill in your secrets.
# =========================================================================

# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Express backend port configuration
BACKEND_PORT=5000

# Next.js frontend envs (Publicly available to client)
NEXT_PUBLIC_BACKEND_URL="http://localhost:5000"

# Gemini AI API Configuration
AI_API_PROVIDER="gemini"
AI_API_KEY="AI_API_KEY"

# Discord Bot Credentials & Webhooks
DISCORD_BOT_TOKEN="DISCORD_BOT_TOKEN"
DISCORD_WEBHOOK_URL="DISCORD_WEBHOOK_URL"
