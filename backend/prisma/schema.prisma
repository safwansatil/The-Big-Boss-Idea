datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Device {
  id          String   @id
  name        String
  type        String // "fan" | "light"
  room        String // "drawing" | "work1" | "work2"
  status      String // "on" | "off"
  powerDraw   Int      // Watts (Fan: 60W when ON, Light: 15W when ON, 0W when OFF)
  lastChanged DateTime @default(now())
}

model AlertLog {
  id        String   @id @default(uuid())
  type      String   // "after-hours" | "stuck-on"
  room      String   // "drawing" | "work1" | "work2"
  deviceIds Json     // JSON array of device IDs: e.g., ["work1-fan-1", "work1-light-2"]
  message   String
  aiMessage String?  // Optional AI-enhanced prose (nullable)
  timestamp DateTime @default(now())
  resolved  Boolean  @default(false)
}
